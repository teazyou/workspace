#!/bin/bash

source "$HOME/.config/sketchybar/colors.sh"
source "$HOME/.config/sketchybar/icons.sh"
# Visual template (division geometry: corner radius, border, blur, shadow, gap).
# Single source of truth — change a value there to restyle the whole bar.
source "$HOME/.config/sketchybar/theme.sh"

# Exported so consumers spawned as subprocesses see them: items/*.sh are sourced
# (inherit these anyway), but script=-spawned plugins run as separate processes
# and rely on FONT / PLUGIN_DIR being in the environment.
export ITEM_DIR="$HOME/.config/sketchybar/items"
export PLUGIN_DIR="$HOME/.config/sketchybar/plugins"

# Font from neutonfoo/dotfiles
export FONT="JetBrainsMono Nerd Font"

# Side inset of the bar content from each screen edge. With margin=0 (below) this
# is the SOLE source of the left/right edge gap, so the first/last division sits
# exactly this far from the screen edge. KEEP IT EQUAL TO aerospace
# gaps.outer.left/right (=5 in aerospace.toml) so the bar's outer divisions line up
# with the tiled-window ("app") area edges. Applied to BOTH padding_left and
# padding_right so the left (spaces) and right (status) groups stay symmetric; the
# right-most item (time) carries no outer label.padding_right.
BAR_SIDE_PADDING=5

# Setting up the general bar appearance - CriticalElement floating style.
# The bar fill stays fully TRANSPARENT (color=$TRANSPARENT). A coloured bar fills
# the ENTIRE width — including the empty middle between the left/right groups — so
# it renders as a full-width rectangle that tints the wallpaper. Instead the grey
# lives on the item groups only (the brackets, via DARK_BG), so just the left +
# right pill clusters are tinted and the wallpaper shows through everywhere else.
bar=(
  height=58
  color=$TRANSPARENT
  shadow=off
  position=top
  sticky=on
  padding_left=$BAR_SIDE_PADDING
  padding_right=$BAR_SIDE_PADDING
  y_offset=-6
  margin=0          # edge gap comes solely from BAR_SIDE_PADDING (kept = aerospace outer.left/right)
  blur_radius=0
  notch_width=0
)

sketchybar --bar "${bar[@]}"

# Setting up default values - CriticalElement pill style
defaults=(
  updates=when_shown
  icon.font="$FONT:Bold:19.0"
  icon.color=$PINK
  icon.padding_left=12
  icon.padding_right=4
  icon.y_offset=1
  label.font="$FONT:Bold:12.0"
  label.color=$LABEL_COLOR
  label.padding_left=4
  label.padding_right=12
  background.color=$DARK_BG
  background.height=30
  background.corner_radius=$DIVISION_RADIUS
  background.drawing=on
  background.border_width=$DIVISION_BORDER_WIDTH
  background.padding_left=8
  blur_radius=$DIVISION_BLUR
  y_offset=2
  popup.background.border_width=2
  popup.background.corner_radius=$POPUP_RADIUS
  popup.background.border_color=$POPUP_BORDER_COLOR
  popup.background.color=$POPUP_BACKGROUND_COLOR
  popup.background.shadow.drawing=on
)

sketchybar --default "${defaults[@]}"

# Shared bracket style for the right-side groups (calendar, audio, resources,
# connectivity, traffic). One definition so a theme change is a single edit.
# NOTE: the left spaces brackets use a DISTINCT spaces_bracket_style in
# items/spaces.sh (without the background.padding_left/right=0 lines) to keep
# the left-group spacing unchanged. Defined before the first item source so
# spaces.sh and the right groups can both reference the convention.
bracket_style=(
  background.color=$DARK_BG
  background.corner_radius=$DIVISION_RADIUS
  background.border_width=$DIVISION_BORDER_WIDTH
  background.border_color=$PINK
  blur_radius=$DIVISION_BLUR
  background.height=32
  background.drawing=on
  background.padding_left=0
  background.padding_right=0
  background.shadow.drawing=$DIVISION_SHADOW_DRAWING
  background.shadow.color=$DIVISION_SHADOW_COLOR
  background.shadow.angle=$DIVISION_SHADOW_ANGLE
  background.shadow.distance=$DIVISION_SHADOW_DISTANCE
)

# Shared base for the monitor pills (cpu, ram, network_up, network_down). These
# items are SOURCED (not spawned), so they see this array in the same shell.
# Each item appends only its per-item overrides (glyph, seed label, icon
# paddings, label.padding_right, and update_freq/script for the active pollers —
# network_up is passive). One definition so a restyle of the pills is one edit.
monitor_item_base=(
  icon.font="$FONT:Normal:15.0"
  icon.color=$PINK
  icon.padding_right=$ELEMENT_GAP
  label.font="$FONT:Bold:14.0"
  label.color=$PINK
  label.padding_left=0
  background.drawing=off
  padding_left=0
  padding_right=0
)

# Left Side Items
# source "$ITEM_DIR/apple.sh"
source "$ITEM_DIR/spaces.sh"

# Right Side Items (order matters, right-most first)
# source "$ITEM_DIR/settings.sh"
source "$ITEM_DIR/calendar.sh"

# Bracket for calendar group (time + date)
sketchybar --add bracket calendar_group time date \
           --set calendar_group "${bracket_style[@]}"

# Spacer between calendar and audio
sketchybar --add item spacer0 right --set spacer0 width=$GROUP_GAP background.drawing=off icon.drawing=off label.drawing=off

# Audio group: volume + bluetooth headset
source "$ITEM_DIR/volume.sh"
source "$ITEM_DIR/headset.sh"

# Spacer between audio and resources
sketchybar --add item spacer1 right --set spacer1 width=$GROUP_GAP background.drawing=off icon.drawing=off label.drawing=off

# System resources group (L->R: cpu, ram, battery). Right items are added
# right-most first, so source battery (rightmost/last), then ram, then cpu.
source "$ITEM_DIR/battery.sh"
source "$ITEM_DIR/ram.sh"
source "$ITEM_DIR/cpu.sh"

# Spacer between resources and connectivity
sketchybar --add item spacer2 right --set spacer2 width=$GROUP_GAP background.drawing=off icon.drawing=off label.drawing=off

# Network connectivity group (L->R: wifi, ethernet, vpn). Right items are added
# right-most first, so source vpn (rightmost), then ethernet, then wifi (leftmost)
# — this puts ethernet immediately to the right of wifi.
source "$ITEM_DIR/vpn.sh"
source "$ITEM_DIR/ethernet.sh"
source "$ITEM_DIR/wifi.sh"

# Spacer between connectivity and the traffic divisions
sketchybar --add item spacer3 right --set spacer3 width=$GROUP_GAP background.drawing=off icon.drawing=off label.drawing=off

# Network traffic — TWO separate divisions: down (right) and up (left). Each shows
# only when its direction has traffic (plugins/network_speed.sh). network_down
# (rightmost) is the sole poller; spacer_ud is the gap between the two divisions.
source "$ITEM_DIR/network_down.sh"
sketchybar --add item spacer_ud right --set spacer_ud width=$GROUP_GAP background.drawing=off icon.drawing=off label.drawing=off
source "$ITEM_DIR/network_up.sh"

# Bracket for audio group (volume + headset)
sketchybar --add bracket audio volume headset \
           --set audio "${bracket_style[@]}"

# Brackets — one per traffic direction, so up and down are separate divisions
sketchybar --add bracket traffic_down network_down \
           --set traffic_down "${bracket_style[@]}"
sketchybar --add bracket traffic_up network_up \
           --set traffic_up "${bracket_style[@]}"

# Bracket for system resources group (battery + cpu + ram)
sketchybar --add bracket resources ram cpu battery \
           --set resources "${bracket_style[@]}"

# Bracket for network connectivity group (ethernet + wifi + vpn)
sketchybar --add bracket connectivity vpn wifi ethernet \
           --set connectivity "${bracket_style[@]}"

# Paint the spaces strip once at startup. Run the coordinator plugin DIRECTLY
# instead of `sketchybar --trigger aerospace_workspace_change`: a custom-event
# trigger fired from here does NOT reliably reach the coordinator item that was
# just --subscribed a few lines earlier, so the spaces stay stuck in their static
# number-only seed state (icon=N, empty label) until the first real workspace
# switch re-fires the event via aerospace's exec-on-workspace-change. A direct
# call is the exact same lightweight repaint (one shell + 3 aerospace queries +
# 1 batched --set), NOT the `sketchybar --update` thundering herd that would
# synchronously run EVERY polling plugin. update_freq items self-populate from
# their literal label= seeds on their own first tick regardless.
"$PLUGIN_DIR/aerospace.sh"

echo "sketchybar configuration loaded..."
