#!/usr/bin/env bash
#
# obsidian — plant the shared Obsidian config into a folder and open it as a vault.
#
# Usage:  obsidian [folder]      (folder defaults to the current directory ".")
#
# Obsidian cannot natively share one config across vaults: every vault folder
# needs its own ".obsidian/" directory. This command makes that ".obsidian"
# a SYMLINK to a single central config dir, so all your vaults share the same
# plugins / snippets / hotkeys / appearance, and then opens the folder in
# Obsidian — the editor equivalent of `code .`.
#
# Central config dir (the symlink target):
#     /Users/teazyou/workspace/configs/dot-obsidian
#
# Behavior:
#   1. Resolve <folder> to an absolute path; error if missing / not a dir.
#   2. If <folder>/.obsidian already exists (real dir OR symlink): leave it
#      completely untouched and just open the vault.
#   3. Otherwise: create the symlink <folder>/.obsidian -> central config,
#      wipe the shared per-vault runtime-state files (so the new window opens
#      clean), then open the vault.
#
# OPEN MECHANISM (chosen + caveat):
#   We register the vault in Obsidian's registry
#   (~/Library/Application Support/obsidian/obsidian.json) with a fresh
#   16-hex id + millisecond timestamp, written atomically (tmp file + mv),
#   then trigger `open "obsidian://open?path=<url-encoded-abs-path>"`.
#
#   Why not just `open -a Obsidian "<folder>"`? Passing a bare folder to the
#   Obsidian.app bundle does NOT reliably register/open an arbitrary folder as
#   a vault — it tends to re-focus the last vault or do nothing. The
#   obsidian:// URI with an explicit registry entry is the reliable path.
#
#   CAVEAT: Obsidian caches its vault registry in memory at launch. If Obsidian
#   is ALREADY RUNNING and you open a brand-new (never-before-registered)
#   folder, the running instance may not see the just-written registry entry,
#   so the obsidian:// URI can be ignored. We detect this case and print a
#   one-line notice telling you to quit & relaunch Obsidian (or just run the
#   command again after it restarts) instead of failing silently. Folders that
#   are already registered open instantly with no restart needed.

set -euo pipefail

readonly CENTRAL="/Users/teazyou/workspace/configs/dot-obsidian"
readonly REGISTRY="$HOME/Library/Application Support/obsidian/obsidian.json"

usage() {
  cat <<'EOF'
obsidian — plant the shared Obsidian config into a folder and open it.

USAGE:
    obsidian [folder]      folder defaults to "." (current directory)

EXAMPLES:
    obsidian .             open the current directory as an Obsidian vault
    obsidian ~/notes       open ~/notes as a vault

The first time a folder is opened, a ".obsidian" symlink pointing at the
shared central config is planted inside it. Folders that already have a
".obsidian" (real or symlink) are opened as-is and left untouched.

Central config: /Users/teazyou/workspace/configs/dot-obsidian
EOF
}

err() { printf 'obsidian: %s\n' "$1" >&2; }

case "${1-}" in
  -h|--help) usage; exit 0 ;;
esac

# ---- 1. Resolve folder to an absolute path -------------------------------
raw_folder="${1-.}"

if [[ ! -e "$raw_folder" ]]; then
  err "no such file or directory: $raw_folder"
  exit 1
fi
if [[ ! -d "$raw_folder" ]]; then
  err "not a directory: $raw_folder"
  exit 1
fi

# Absolute, symlink-resolved path. cd+pwd handles spaces and relative paths.
folder="$(cd "$raw_folder" && pwd -P)"

config_link="$folder/.obsidian"

# ---- 2/3. Plant symlink + clean state (only if no .obsidian yet) ----------
if [[ -e "$config_link" || -L "$config_link" ]]; then
  # Already has a .obsidian (real dir, or an existing symlink). Leave it alone.
  printf 'obsidian: %s already has a .obsidian — opening as-is\n' "$folder"
else
  if [[ ! -d "$CENTRAL" ]]; then
    err "central config dir not found: $CENTRAL"
    exit 1
  fi
  ln -s "$CENTRAL" "$config_link"
  printf 'obsidian: linked %s/.obsidian -> %s\n' "$folder" "$CENTRAL"

  # Wipe shared per-vault runtime state so the new window opens clean. These
  # live directly in the central dir and are reachable through the new symlink;
  # they are git-ignored and regenerated by Obsidian.
  rm -rf -- \
    "$CENTRAL/workspace.json" \
    "$CENTRAL/workspace-mobile.json" \
    "$CENTRAL/graph.json" \
    "$CENTRAL/file-recovery.json" \
    "$CENTRAL/file-recovery"
fi

# ---- 4. Open the vault ----------------------------------------------------

# URL-encode a string for use in the obsidian:// path query parameter.
urlencode() {
  local s="$1" out="" c i
  for (( i = 0; i < ${#s}; i++ )); do
    c="${s:i:1}"
    case "$c" in
      [a-zA-Z0-9.~_-]) out+="$c" ;;
      *) out+="$(printf '%%%02X' "'$c")" ;;
    esac
  done
  printf '%s' "$out"
}

# Is this folder already present in the registry? (already-registered vaults
# open instantly even while Obsidian is running.)
already_registered=0
if [[ -f "$REGISTRY" ]] && grep -Fq "\"$folder\"" "$REGISTRY"; then
  already_registered=1
fi

# Register the vault (fresh id + ms timestamp) if not present, written
# atomically via a tmp file + mv so a crash can't corrupt the registry.
register_vault() {
  local id ts tmp
  id="$(hexdump -n 8 -e '8/1 "%02x"' /dev/urandom)"   # 16 hex chars
  ts="$(date +%s)000"                                  # ms since epoch

  mkdir -p "$(dirname "$REGISTRY")"

  if [[ -f "$REGISTRY" ]] && command -v python3 >/dev/null 2>&1; then
    # Merge into existing registry with python3 (robust JSON handling).
    tmp="$(mktemp "${REGISTRY}.XXXXXX")"
    REG_PATH="$REGISTRY" NEW_ID="$id" NEW_TS="$ts" VAULT_PATH="$folder" \
      python3 - "$tmp" <<'PY'
import json, os, sys
reg_path = os.environ["REG_PATH"]
tmp = sys.argv[1]
try:
    with open(reg_path) as f:
        data = json.load(f)
except Exception:
    data = {}
vaults = data.setdefault("vaults", {})
# Skip if this path is already registered under some id.
target = os.environ["VAULT_PATH"]
if not any(v.get("path") == target for v in vaults.values()):
    vaults[os.environ["NEW_ID"]] = {"path": target, "ts": int(os.environ["NEW_TS"])}
with open(tmp, "w") as f:
    json.dump(data, f)
PY
    mv -f "$tmp" "$REGISTRY"
  else
    # No existing registry (or no python3): create a minimal one atomically.
    tmp="$(mktemp "${REGISTRY}.XXXXXX")"
    printf '{"vaults":{"%s":{"path":"%s","ts":%s}}}' "$id" "$folder" "$ts" > "$tmp"
    mv -f "$tmp" "$REGISTRY"
  fi
}

if [[ "$already_registered" -eq 0 ]]; then
  register_vault
fi

encoded="$(urlencode "$folder")"
open "obsidian://open?path=$encoded"

# If we just registered a NEW vault while Obsidian is already running, the
# running instance may have a cached registry and ignore the URI. Warn once.
if [[ "$already_registered" -eq 0 ]] && pgrep -x Obsidian >/dev/null 2>&1; then
  printf 'obsidian: opened %s.\n' "$folder"
  printf 'obsidian: note — this folder was newly registered while Obsidian was\n'
  printf '          already running. If the window did not appear, quit Obsidian\n'
  printf '          (Cmd-Q) and run this command again; the registry is cached\n'
  printf '          at launch.\n'
else
  printf 'obsidian: opened %s\n' "$folder"
fi
