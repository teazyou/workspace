{
    "workbench.startupEditor": "none",
    "extensions.ignoreRecommendations": true,
    "[javascript]": {
        "editor.defaultFormatter": "dbaeumer.vscode-eslint"
    },
    "[markdown]": {
        "diffEditor.ignoreTrimWhitespace": true,
        "editor.formatOnSave": true,
        "editor.formatOnPaste": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.markdownlint": "explicit"
        }
    },
    "github.copilot.nextEditSuggestions.enabled": true,
    "editor.formatOnSave": true,
    "notebook.formatOnSave.enabled": true,
    "debug.console.fontSize": 16,
    "terminal.integrated.fontSize": 15,
    "kilo-code.allowedCommands": [
        "git log",
        "git diff",
        "git show",
        "npm run",
        "python3 -m http.server 8000",
        "python3",
        "npm init",
        "npm",
        "npm init -y",
        "mkdir",
        "npx",
        "git init",
        "git clone",
        "npm install",
        "node",
        "npm test",
        "grep",
        "tail",
        "ls",
        "test",
        "echo",
        "head",
        "cat",
        "cp",
        "npm start"
    ],
    "kilo-code.deniedCommands": [],
    "workbench.editor.empty.hint": "hidden",
    "editor.accessibilitySupport": "off",
    "editor.autoIndentOnPaste": true,
    "editor.insertSpaces": true,
    "editor.tabSize": 4,
    "editor.detectIndentation": false,
    "eslint.codeActionsOnSave.rules": null,
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit"
    },
    "python.defaultInterpreterPath": "/opt/homebrew/bin/python3.13",
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "accessibility.signalOptions.volume": 5,
    "git.confirmSync": false,
    "git.scanRepositories": [
        "/Users/teazyou/dev/sopaios-playground/.sopaios"
    ],
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "window.title": "${folderName}",
    "explorer.confirmDragAndDrop": false,
    "markdown.preview.linkify": false,
    "markdown.preview.fontSize": 24,
    "workbench.iconTheme": "material-icon-theme",
    "material-icon-theme.folders.color": "#42a5f5",
    "workbench.settings.applyToAllProfiles": [],
    "material-icon-theme.folders.associations": { // https://github.com/material-extensions/vscode-material-icon-theme/tree/main/src/core/icons
        "10. AI": "robot",
        "99. WUTHERING": "console",
        "99. GENSHIN": "console",
        "31. DEV": "github",
        "claude": "claude",
        ".claude": "claude",
        "20. KNOWLEDGE": "bibliography",
        "Excalidraw": "config"
    },
    "markdownlint.config": {
        "MD013": false,
        "MD029": false,
        "MD034": false
    },
    "editor.minimap.enabled": false,
    "window.titleBarStyle": "native",
    "github.copilot.enable": {
        "plaintext": true,
        "markdown": true
    },
    "workbench.statusBar.visible": false,
    "chat.viewSessions.orientation": "stacked",
    "window.customTitleBarVisibility": "never",
    "workbench.activityBar.location": "top",
    "workbench.colorTheme": "Red",
    "workbench.colorCustomizations": {
        "terminal.background": "#1e1e1eff",
        "editorPane.background": "#1e1e1eff",
        "editorGroupHeader.tabsBackground": "#1e1e1eff",
        "editorGroupHeader.noTabsBackground": "#1e1e1eff",
        "breadcrumb.background": "#1e1e1eff",
        "editorGutter.background": "#1e1e1eff",
        "panel.background": "#1e1e1eff",
        "panelStickyScroll.background": "#1e1e1eff",
        "tab.activeBackground": "#fd575763",
        "tab.unfocusedActiveBackground": "#b2141425",
        "tab.activeBorder": "#ff3030",
        "tab.unfocusedActiveBorder": "#ff3030FF",
        "tab.activeForeground": "#ffffffEE",
        "sideBar.background": "#1e1e1eff",
        "sideBarTitle.background": "#1e1e1eff",
        "sideBarStickyScroll.background": "#1e1e1eff",
        "activityBar.background": "#1e1e1eff",
        "editor.background": "#1e1e1eff",
        "editorStickyScroll.background": "#1e1e1eff",
        "editorStickyScrollGutter.background": "#1e1e1eff",
        "tab.inactiveBackground": "#1e1e1eff",
        "tab.unfocusedInactiveBackground": "#1e1e1eff",
        "inlineChat.background": "#1e1e1eff",
        "editorWidget.background": "#1e1e1eff",
        "editorHoverWidget.background": "#1e1e1eff",
        "editorSuggestWidget.background": "#1e1e1eff",
        "notifications.background": "#1e1e1eff",
        "notificationCenterHeader.background": "#1e1e1eff",
        "menu.background": "#1e1e1eff",
        "quickInput.background": "#1e1e1eff",
        "widget.border": "#b22222dd",
        "editorWidget.border": "#b22222dd",
        "editorHoverWidget.border": "#b22222",
        "editorSuggestWidget.border": "#b22222",
        "inlineChat.border": "#b22222",
        "menu.border": "#b22222",
        "pickerGroup.border": "#b22222",
        "notifications.border": "#b22222",
        "notificationCenter.border": "#b22222",
        "notificationToast.border": "#b22222"
    },
    "breadcrumbs.enabled": false,
    "workbench.editor.closeEmptyGroups": true,
    "workbench.editor.enablePreview": true,
    "workbench.editor.enablePreviewFromQuickOpen": true,
    "workbench.editor.enablePreviewFromCodeNavigation": true,
    "redhat.telemetry.enabled": false,
    "diffEditor.hideUnchangedRegions.enabled": true,
    "editor.fontSize": 16
}
