#!/bin/bash

# Dark red themed borders
# Style options: round, square, uniform
# Color format: 0xAARRGGBB (A=alpha, R=red, G=green, B=blue)

options=(
    style=round
    width=1.0
    hidpi=on
    active_color=0xff9e2020
    # Unfocused windows get NO border (fully transparent — JankyBorders has no
    # "draw active only" toggle, so a transparent inactive colour is how we hide it).
    inactive_color=0x00000000
    # Additional options available:
    # background_color=0x00000000
    # ax_focus=on
    # blacklist="App1,App2"
    # whitelist="App1,App2"
)

borders "${options[@]}"
