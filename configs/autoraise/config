# AutoRaise config — focus-follows-mouse for the AeroSpace setup.
# Source of truth: ~/workspace/configs/autoraise/config
# Symlinked to ~/.config/AutoRaise/config (the path AutoRaise reads).
# Format: key=value, one per line, strings double-quoted.
# After editing: `brew services` not used — restart via the LaunchAgent
# (see com.autoraise.daemon.plist) or just `pkill AutoRaise` (KeepAlive respawns it).

# How often the mouse position is polled (ms) — the responsiveness knob, and the
# floor on how fast a mouse-stop can be detected. 50 = default/snappy, light on CPU
# (minimum 20). NOTE: a high value (e.g. 200) does NOT make focus more "deliberate",
# it just adds latency before the stop is noticed — the deliberate / no-fly-over-steal
# behavior comes entirely from requireMouseStop below.
pollMillis=50

# Raise/focus delay in units of pollMillis. delay=1 = no dwell: as soon as the mouse
# comes to rest (enforced by requireMouseStop below) the window under it is raised/
# focused on the next ~50ms poll — the snappiest setting that still requires a stop.
# delay=0 disables raising entirely; delay>1 adds a dwell (delay=2 ≈ 50ms, 3 ≈ 100ms).
delay=1

# Hold this key to temporarily suppress AutoRaise. "option" = alt, which is the
# modifier behind EVERY AeroSpace binding (alt+hjkl focus, alt+shift+hjkl move,
# alt+1-9 workspace). So the whole time you're doing keyboard window management
# focus-follows-mouse is gated off and can't hijack the window under the cursor.
# Also a manual guard for quick gestures: hold alt while flicking up to the Apple
# menu / SketchyBar and nothing on the way steals focus.
disableKey="option"

# Require the mouse to come to rest before focusing — a quick flick across a window
# (e.g. up to the menu bar / SketchyBar) won't steal focus, only a deliberate stop does.
requireMouseStop=true

# Ignore mouse jitter smaller than this before considering a focus change. Raised
# from 0.1 so small unintentional nudges while the cursor rests don't re-trigger focus.
mouseDelta=1.0

# Don't re-focus immediately after a Space/workspace change.
ignoreSpaceChanged=true

# Cursor warping is handled by AeroSpace's mouse-follows-focus callback
# (on-focus-changed = move-mouse window-lazy-center in aerospace.toml), so
# AutoRaise's own warp is left disabled to avoid two tools fighting over the cursor.
