# AutoRaise config — focus-follows-mouse for the AeroSpace setup.
# Source of truth: ~/workspace/configs/autoraise/config
# Symlinked to ~/.config/AutoRaise/config (the path AutoRaise reads).
# Format: key=value, one per line, strings double-quoted.
# After editing: `brew services` not used — restart via the LaunchAgent
# (see com.autoraise.daemon.plist) or just `pkill AutoRaise` (KeepAlive respawns it).

# How often the mouse position is polled (ms). 50 = default, light on CPU.
pollMillis=50

# Raise/focus delay in units of pollMillis. delay=1 = snappiest: focus the
# window under the cursor after a single ~50ms poll, with NO required mouse-stop,
# so hover-to-focus feels instant (this is the action done constantly).
# delay=0 would disable focusing entirely, so 1 is the floor. delay>1 would
# re-introduce a rest-before-focus wait, which felt too slow.
delay=1

# Hold this key to temporarily suppress AutoRaise. "option" = alt, which is the
# modifier behind EVERY AeroSpace binding (alt+hjkl focus, alt+shift+hjkl move,
# alt+1-9 workspace). So the whole time you're doing keyboard window management
# focus-follows-mouse is gated off and can't hijack the window under the cursor.
# This is ALSO the menu-bar guard now that the delay is gone: hold alt while
# flicking up to the Apple menu / SketchyBar and nothing on the way steals focus.
disableKey="option"

# Don't wait for the mouse to halt before focusing — keeps hover-to-focus instant.
# The single-poll delay above still debounces sub-50ms pass-throughs.
requireMouseStop=false

# Ignore mouse jitter smaller than this before considering a focus change.
mouseDelta=0.1

# Don't re-focus immediately after a Space/workspace change.
ignoreSpaceChanged=true

# Cursor warping is handled by AeroSpace's mouse-follows-focus callback
# (on-focus-changed = move-mouse window-lazy-center in aerospace.toml), so
# AutoRaise's own warp is left disabled to avoid two tools fighting over the cursor.
